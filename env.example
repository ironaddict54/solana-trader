# Solana RPC endpoint - use a dedicated provider for reliability
# Recommended: Helius (https://helius.dev) or QuickNode (https://quicknode.com)
RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Your wallet private key in base58 format
# NEVER commit this file with a real key
WALLET_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY

# Slippage tolerance in basis points (100 = 1%)
SLIPPAGE_BPS=50

# Strategies to enable (comma-separated): dca,limitOrder,takeProfitStopLoss,rebalance
ENABLED_STRATEGIES=dca,limitOrder,takeProfitStopLoss,rebalance

# ---- DCA CONFIG ----
# Token mint address to buy
DCA_TOKEN_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Amount in USD to buy each interval
DCA_AMOUNT_USD=10
# Cron schedule (default: every day at 9am)
DCA_CRON=0 9 * * *
# Input token mint (default: USDC)
DCA_INPUT_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ---- LIMIT ORDER CONFIG ----
# Token mint to watch
LIMIT_TOKEN_MINT=So11111111111111111111111111111111111111112
# Buy when price drops to this USD value
LIMIT_BUY_PRICE=120
# Sell when price rises to this USD value
LIMIT_SELL_PRICE=200
# Amount in USD to buy/sell
LIMIT_AMOUNT_USD=50
# Poll interval in seconds
LIMIT_POLL_SECONDS=30

# ---- TAKE PROFIT / STOP LOSS CONFIG ----
# Token mint to watch
TPSL_TOKEN_MINT=So11111111111111111111111111111111111111112
# Entry price in USD (price you bought at)
TPSL_ENTRY_PRICE=150
# Take profit % gain (e.g. 20 = sell when up 20%)
TPSL_TAKE_PROFIT_PCT=20
# Stop loss % loss (e.g. 10 = sell when down 10%)
TPSL_STOP_LOSS_PCT=10
# Amount of token (in token units, e.g. lamports for SOL) to sell
TPSL_SELL_AMOUNT=1000000000
# Poll interval in seconds
TPSL_POLL_SECONDS=15

# ---- REBALANCE CONFIG ----
# JSON array of { mint, targetPct } - must sum to 100
# Example: SOL 50%, USDC 50%
REBALANCE_TARGETS=[{"mint":"So11111111111111111111111111111111111111112","targetPct":50},{"mint":"EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v","targetPct":50}]
# Rebalance only if a token drifts more than this % from target
REBALANCE_THRESHOLD_PCT=5
# Cron schedule (default: every Sunday at midnight)
REBALANCE_CRON=0 0 * * 0
